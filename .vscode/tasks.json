        {
            "label": "CCS Build (Debug)",
            "type": "shell",
            "command": "C:\\ti\\ccs1271\\ccs\\eclipse\\eclipsec.exe",
            "args": [
                "-noSplash",
                "-data",
                "D:\\47 HDFC10kWNCM_PackBMSR1\\.metadata",
                "-application",
                "com.ti.ccstudio.apps.projectBuild",
                "-ccs.projects",
                "F28069PackBMS",
                "-ccs.configuration",
                "Debug"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": {
                "owner": "ti-c2000",
                "fileLocation": ["relative", "${workspaceFolder}"],
                "pattern": {
                    "regexp": "^\"(.+)\",\\s*line\\s*(\\d+):\\s*(error|warning|remark)\\s*#(\\d+):\\s*(.+)$",
                    "file": 1,
                    "line": 2,
                    "severity": 3,
                    "code": 4,
                    "message": 5
                }
            },
            "detail": "CCS 12 커맨드라인 빌드 (Debug 구성)"
        },
